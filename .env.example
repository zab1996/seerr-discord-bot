# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional but recommended: your Discord server ID for instant slash commands
# Enable Developer Mode in Discord → right-click server → Copy Server ID
DISCORD_GUILD_ID=

# Command prefix for text commands (slash commands always work)
COMMAND_PREFIX=!

# Label shown for library availability (embed field + footer)
LIBRARY_NAME=Library

# Label on the request button
REQUEST_BUTTON_LABEL=Request

# Seerr / Overseerr instance (no trailing slash)
# From Docker: http://host.docker.internal:5055 (host) or http://seerr:5055 (same network)
SEERR_URL=http://host.docker.internal:5055
SEERR_API_KEY=

# OMDb API key only (not the full URL) from http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# Optional: custom Seerr logo emoji uploaded to your Discord server
# Leave blank to use a default request button without a custom emoji
SEERR_EMOJI_NAME=seerr
SEERR_EMOJI_ID=

# Optional: absolute path to this project when bind-mounting via Docker/Dockge
# HOST_BOT_PATH=/path/to/seerr-discord-bot
